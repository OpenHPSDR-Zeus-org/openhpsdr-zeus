#!/bin/sh
set -eu

expected_primary="Christian Suarez (N9WAR) <christiantsuarez@gmail.com>"
expected_handle="iamexemplar <christiantsuarez@gmail.com>"

is_expected_identity() {
  case "$1" in
    *"$expected_primary"*|*"$expected_handle"*)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

author_ident="$(git var GIT_AUTHOR_IDENT 2>/dev/null || true)"
committer_ident="$(git var GIT_COMMITTER_IDENT 2>/dev/null || true)"

if ! is_expected_identity "$author_ident"; then
  echo "Refusing commit with unexpected author identity:" >&2
  echo "  $author_ident" >&2
  echo "Expected one of:" >&2
  echo "  $expected_primary" >&2
  echo "  $expected_handle" >&2
  exit 1
fi

if ! is_expected_identity "$committer_ident"; then
  echo "Refusing commit with unexpected committer identity:" >&2
  echo "  $committer_ident" >&2
  echo "Expected one of:" >&2
  echo "  $expected_primary" >&2
  echo "  $expected_handle" >&2
  exit 1
fi

branch="$(git symbolic-ref --quiet --short HEAD 2>/dev/null || true)"
case "$branch" in
  main|develop)
    if [ "${ZEUS_ALLOW_PROTECTED_BRANCH_COMMIT:-}" != "1" ]; then
      echo "Refusing commit on protected branch '$branch'." >&2
      echo "Start scoped work with: pwsh scripts/start-work.ps1 feature '<short name>'" >&2
      exit 1
    fi
    ;;
esac
